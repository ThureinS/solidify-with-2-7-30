# Postgres connection string. Locally this matches docker-compose.yml's db service.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/spaced_repetition"

# Port the Express server listens on locally.
PORT=3000

# Secret key used to sign and verify JWTs. Any long random string works locally;
# generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-string"

# Production only (Neon): a DIRECT, non-pooled connection string, used only
# for running migrations (prisma.config.ts prefers this over DATABASE_URL).
# Pooled connections don't reliably support the locking Prisma Migrate needs.
# Not needed locally -- Docker Postgres has no pooler, so this is left unset.
# DATABASE_URL_UNPOOLED="postgresql://..."

# Redis connection string. Locally this matches docker-compose.yml's redis service.
# Used for the BullMQ email queue (and later a refresh-token store). Prod (Vercel)
# has no Redis, so a deployed build needs a managed one (e.g. Upstash).
REDIS_URL="redis://localhost:6379"

# Gmail account the welcome-email worker sends from. GMAIL_APP_PASSWORD is a
# 16-character App Password (requires 2-Step Verification), NOT your normal
# Gmail password: https://myaccount.google.com/apppasswords
GMAIL_USER="your-address@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Comma-separated list of origins allowed to call this API from a browser
# (the frontend's dev server locally, its deployed URL in production).
# Defaults to the Vite dev server port if unset.
CORS_ORIGIN="http://localhost:5173"
